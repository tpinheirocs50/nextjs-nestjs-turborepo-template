# ============================================================
# Environment variables for `pnpm docker:up` / `docker compose`
# ============================================================
# Copy this file to .env (gitignored) and fill in real values.
# This file is the canonical source of "what env vars does the
# Docker stack need?". Per-app .env files (apps/api/.env,
# apps/web/.env) are used for local pnpm dev workflows only.

# ---- Required ----

# Better Auth: signing secret for sessions and cookie cache.
# Must be at least 32 characters. Must match across api and web.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ---- Optional: Google OAuth ----
# Leave unset to disable Google sign-in. To enable, register an
# OAuth app at https://console.cloud.google.com/ and paste the
# values here. See README "Google OAuth setup" for details.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Optional: GitHub OAuth ----
# Leave unset to disable GitHub sign-in. To enable, register an
# OAuth app at https://github.com/settings/developers and paste
# the values here. See README "GitHub OAuth setup" for details.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend — transactional email (optional)
# Without these, email verification is disabled in the Docker stack.
# See README "Email setup (Resend)".
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev