# Version control
.git
.gitignore

# Dependencies
**/node_modules
**/.pnpm-store

# Build outputs
**/dist
**/.next
**/.turbo
**/build

# Environment files (secrets shouldn't go into images)
**/.env
**/.env.local
**/.env.*.local

# IDE and OS
.vscode
.idea
.DS_Store
**/*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Testing
**/coverage

# Docker (don't recursively reference itself)
Dockerfile
.dockerignore
docker-compose*.yml

# Generated Prisma clients (regenerated during build)
**/src/prisma/generated

# Documentation
README.md
LICENSE
*.md

# CI
.github

# Misc
.editorconfig
.nvmrc