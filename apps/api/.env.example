# Node environment
NODE_ENV=development

# Port the API listens on
PORT=3001

# CORS allowed origin (the web app's URL)
CORS_ORIGIN=http://localhost:3000

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/monorepo?schema=public"

LOG_LEVEL=info

# Better Auth — required for any auth at all
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth — optional, leave empty to disable
# Get credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — optional, leave empty to disable
# Get credentials at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend — transactional email (optional)
# Get an API key at https://resend.com/api-keys
# Without these, email verification and password reset are disabled
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev