generator client {
    provider     = "prisma-client"
    output       = "../src/prisma/generated"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
