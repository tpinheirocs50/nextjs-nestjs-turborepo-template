# Node environment
NODE_ENV=development

# URL of the NestJS API (must include protocol)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-side only (Docker container-to-container). Leave unset for local dev.
# INTERNAL_API_URL=http://api:3001

# Better Auth — must match the secret in apps/api/.env exactly.
# Used by apps/web/src/proxy.ts to verify session cookies signed by the api.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=match-the-secret-in-apps-api-env-must-be-at-least-32-chars